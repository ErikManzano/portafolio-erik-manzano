---
interface Props {
  project: {
    id: number;
    title: string;
    description: string;
    image: string;
    url: string;
    features: string[];
  };
}

const { project } = Astro.props;
---

<div class="col-md-6 row mx-auto my-4" data-aos="fade-up">
  <div class="card-custom rounded-4 bg-base shadow-effect h-100 d-flex flex-column">
    <div class="card-custom-image rounded-4">
      <a href={project.url} target="_blank" rel="noopener noreferrer">
        <img class="rounded-4" src={project.image} alt={project.title} />
      </a>
    </div>
    <div class="card-custom-content p-4">
      <h4>{project.title}</h4>
      <div>
        <p>{project.description}</p>
        <ul class="mb-1">
          {project.features.map((feature) => (
            <li type="circle">{feature}</li>
          ))}
        </ul>
      </div>
      <a href={project.url}rel="noopener noreferrer" class="link-custom">
        Ir al sitio
      </a>
    </div>
  </div>
</div>

<style>
  .card-custom {
    border: none;
    transition: all 0.3s ease;
  }

  .card-custom-image {
    overflow: hidden;
    height: 250px;
  }

  .card-custom-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .card-custom-image:hover img {
    transform: scale(1.05);
  }

  .card-custom-content h4 {
    margin: 0 0 1rem 0;
    font-weight: 700;
  }

  .card-custom-content p {
    margin: 1rem 0;
    color: var(--color-body);
  }

  .card-custom-content ul {
    list-style: none;
    padding-left: 1rem;
  }

  .card-custom-content li {
    margin: 0.5rem 0;
    color: var(--color-body);
  }

  .link-custom {
    color: var(--color-brand);
    font-weight: 600;
    transition: all 0.3s ease;
  }

  .link-custom:hover {
    color: var(--color-brand2);
    text-decoration: underline;
  }
</style>
