    <div class="row gy-4 justify-content-between">
      <div class="col-auto">
        <p class="mb-0">&copy; Copyright 2025. Todos los derechos reservados</p>
      </div>
      <div class="col-auto">
        <div class="social-icons">
          <a href="https://www.linkedin.com/in/erik-jonathan-manzano-morales/" target="_blank" rel="noopener noreferrer">
