---
import ImageSlider from "./ImageSlider.astro";

interface Props {
  title: string;
  description: string;
  year: string;
  role: string;
  industry: string;
  context: string;
  technologies?: string[];
  links?: {
    live?: string;
    repo?: string;
  };
  images?: Array<{ image: string; caption: string }>;
}

const {
  title,
  description,
  year,
  role,
  industry,
  context,
  technologies,
  links,
  images = [],
} = Astro.props;
---

<section class="case-study-hero">
  <div class="container-fluid p-0">
    <div class="hero-unified-wrapper">
      <div class="container mt-5">
        <div class="row gap-1 align-items-center">
          <div class="col-lg-7 col-12">
            <div class="hero-content" data-aos="fade-right">
              <span class="badge-year">{year}</span>
              <h1 class="hero-title mb-3">{title}</h1>
              <p class="hero-description mb-4">{description}</p>

              {
                technologies && technologies.length > 0 && (
                  <div class="meta-item full-width">
                    <span class="meta-label">Tecnologías</span>
                    <p class="meta-value">{technologies.join(", ")}</p>
                  </div>
                )
              }
            </div>

            {
              links && (links.live || links.repo) && (
                <div class="d-flex gap-3">
                  {links.live && (
                    <a
                      href={links.live}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="btn btn-brand"
                    >
                      Live Demo <i class="las la-external-link-alt" />
                    </a>
                  )}
                  {links.repo && (
                    <a
                      href={links.repo}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="btn btn-outline-brand"
                    >
                      GitHub <i class="lab la-github" />
                    </a>
                  )}
                </div>
              )
            }
          </div>
          <div class="row col-lg-5 col-12">
            <div class="meta-grid-unified mb-4">
              <div class="meta-item">
                <span class="meta-label">Usuarios</span>
                <p class="meta-value w-100">{role}</p>
              </div>
            </div>
            <div
              class="context-box-unified"
              data-aos="fade-up"
              data-aos-delay="400"
            >
              <h3 class="context-title">Contexto del Proyecto</h3>
              <p class="context-text">{context}</p>
            </div>
          </div>
          {
            images && images.length > 0 && (
              <div
                class="hero-gallery-top"
                data-aos="fade-down"
                data-aos-delay="100"
              >
                <ImageSlider
                  images={images}
                  id="hero-top-gallery"
                  isHero={true}
                />
              </div>
            )
          }
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .case-study-hero {
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .hero-unified-wrapper {
    position: relative;
    padding: 0 0 6rem 0;
    background:
      radial-gradient(
        circle at top left,
        rgba(164, 128, 247, 0.08),
        transparent 40%
      ),
      radial-gradient(
        circle at bottom right,
        rgba(124, 77, 235, 0.05),
        transparent 40%
      );
  }

  .badge-year {
    display: inline-block;
    background: var(--color-brand);
    color: white;
    padding: 0.4rem 1.2rem;
    border-radius: 2rem;
    font-weight: 700;
    font-size: 0.8rem;
    letter-spacing: 1px;
    margin-bottom: 1.5rem;
    box-shadow: 0 4px 15px rgba(164, 128, 247, 0.3);
  }

  .hero-title {
    font-size: clamp(2.5rem, 4vw, 3rem);
    font-weight: 800;
    line-height: 1.1;
    color: var(--color-heading);
    margin-bottom: 1.5rem;
  }

  .hero-description {
    font-size: 1.15rem;
    line-height: 1.6;
    color: var(--color-body);
    opacity: 0.8;
    max-width: 600px;
  }

  .meta-grid-unified {
    display: flex;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    background: rgba(255, 255, 255, 0.03);
    padding: 1.5rem;
    border-radius: 1rem;
    border: 1px solid rgba(255, 255, 255, 0.05);
    backdrop-filter: blur(10px);
  }

  .meta-item.full-width {
    grid-column: span 2;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    padding-top: 1rem;
  }

  .meta-label {
    display: block;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--color-brand);
    font-weight: 700;
    margin-bottom: 0.25rem;
  }

  .meta-value {
    font-size: 1rem;
    color: #fff;
    font-weight: 600;
    margin: 0;
  }

  .hero-gallery-top {
    width: 100%;
    margin-bottom: 4rem;
  }

  .hero-slider-container {
    position: relative;
    z-index: 2;
  }

  .context-box-unified {
    background: linear-gradient(
      135deg,
      rgba(164, 128, 247, 0.1),
      rgba(124, 77, 235, 0.05)
    );
    border-left: 3px solid var(--color-brand);
    padding: 2rem;
    border-radius: 0 1rem 1rem 0;
    margin-top: 2rem;
  }

  .context-title {
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--color-brand);
    font-weight: 700;
    margin-bottom: 0.75rem;
  }

  .context-text {
    font-size: 1.05rem;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.82);
  }

  @media (max-width: 991px) {
    .hero-unified-wrapper {
      padding: 4rem 0;
    }
    .hero-title {
      font-size: 2.5rem;
    }
    .hero-slider-container {
      margin-left: 0;
      margin-top: 2rem;
    }
    .meta-grid-unified {
      grid-template-columns: 1fr;
    }
    .meta-item.full-width {
      grid-column: span 1;
    }
  }
</style>
