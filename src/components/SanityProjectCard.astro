---
interface Props {
  project: {
    title: string;
    description: string;
    mainImage?: string;
    repositoryUrl?: string;
    liveUrl?: string;
    technologies?: string[];
  };
}

const { project } = Astro.props;
---

<div class="col-md-6 row mx-auto my-4" data-aos="fade-up">
  <div
    class="card-custom rounded-4 bg-base shadow-effect h-100 d-flex flex-column"
  >
    <div class="card-custom-image rounded-4">
      {
        project.liveUrl ? (
          <a href={project.liveUrl} target="_blank" rel="noopener noreferrer">
            <img
              class="rounded-4"
              src={project.mainImage || "/assets/images/placeholder.avif"}
              alt={project.title}
            />
          </a>
        ) : project.repositoryUrl ? (
          <a
            href={project.repositoryUrl}
            target="_blank"
            rel="noopener noreferrer"
          >
            <img
              class="rounded-4"
              src={project.mainImage || "/assets/images/placeholder.avif"}
              alt={project.title}
            />
          </a>
        ) : (
          <img
            class="rounded-4"
            src={project.mainImage || "/assets/images/placeholder.avif"}
            alt={project.title}
          />
        )
      }
    </div>
    <div class="card-custom-content p-4 d-flex flex-column flex-grow-1">
      <h4>{project.title}</h4>
      <div class="flex-grow-1">
        <p>
          {
            project.description.length > 200
              ? project.description.substring(0, 200) + "..."
              : project.description
          }
        </p>

        {
          project.technologies && project.technologies.length > 0 && (
            <div class="mt-3 mb-2">
              <h6 class="text-brand mb-2" style="font-size: 1.25rem;">
                TECNOLOGÍAS
              </h6>
              <div class="d-flex flex-wrap gap-2 fs-">
                {project.technologies.map((tech) => (
                  <span
                    class="badge text-dark"
                    style="background-color: var(--color-body);"
                  >
                    {tech}
                  </span>
                ))}
              </div>
            </div>
          )
        }
      </div>

      <div
        class="d-flex gap-4 mt-4 pt-3"
        style="border-top: 1px solid rgba(255,255,255,0.05);"
      >
        {
          project.liveUrl && (
            <a
              href={project.liveUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="link-custom"
            >
              Ir al sitio
              <i class="las la-external-link-alt" />
            </a>
          )
        }
        {
          project.repositoryUrl && (
            <a
              href={project.repositoryUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="link-custom"
            >
              Código <i class="lab la-github" />
            </a>
          )
        }
      </div>
    </div>
  </div>
</div>

<style>
  .card-custom {
    border: none;
    transition: all 0.3s ease;
  }

  .card-custom-image {
    overflow: hidden;
    height: 400px;
    background-color: transparent;
  }

  .card-custom-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  @media (max-width: 768px) {
    .card-custom-image {
      height: 250px;
    }
  }

  .card-custom-image:hover img {
    transform: scale(1.05);
  }

  .card-custom-content h4 {
    margin: 0 0 1rem 0;
    font-weight: 700;
  }

  .card-custom-content p {
    margin: 1rem 0;
    color: var(--color-body);
  }

  .link-custom {
    color: var(--color-brand);
    font-weight: 600;
    transition: all 0.3s ease;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
  }

  .link-custom:hover {
    color: var(--color-brand2);
  }
</style>
