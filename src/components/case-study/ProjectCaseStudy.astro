---
import ProjectHero from './ProjectHero.astro';
import ProblemSection from './ProblemSection.astro';
import SolutionSection from './SolutionSection.astro';
import AIIntegrationSection from './AIIntegrationSection.astro';
import ImpactSection from './ImpactSection.astro';
import GallerySection from './GallerySection.astro';

interface Props {
  project: {
    title: string;
    summary: string;
    technologies?: string[];
    challenge?: {
      problem?: string;
      user?: string;
    };
    solution?: string;
    aiIntegration?: Array<{
      tool: string;
      usage: string;
    }>;
    metrics?: Array<{
      label: string;
      value: string;
    }>;
    heroImage?: string;
    links?: {
      live?: string;
      repo?: string;
    };
    executiveGallery?: Array<{ image: string; caption: string; category?: string }>;
    processGallery?: Array<{ image: string; caption: string; category?: string }>;
    impactGallery?: Array<{ image: string; caption: string; category?: string }>;
    gallery?: Array<{
      image: string;
      caption: string;
      category?: string;
    }>;
  };
}

const { project } = Astro.props;
---

<div class="project-case-study">
  <ProjectHero
    title={project.title}
    description={project.summary}
    year={new Date().getFullYear().toString()}
    role={project.challenge?.user || "UX/UI Designer"}
    industry={project.technologies ? project.technologies.slice(0, 3).join(", ") : "Digital"}
    context={project.challenge?.problem || project.summary}
    technologies={project.technologies}
    links={project.links}
    images={project.executiveGallery}
  />

  {project.challenge && (
    <ProblemSection
      problem={project.challenge.problem || ""}
      user={project.challenge.user || ""}
      images={project.processGallery || project.gallery?.filter(img => 
        img.category?.toLowerCase().includes('problem') || 
        img.category?.toLowerCase() === 'desafío' ||
        img.category?.toLowerCase() === 'before'
      ).map(img => ({ image: img.image, caption: img.caption, category: img.category }))}
    />
  )}

  {project.solution && (
    <SolutionSection 
      solution={project.solution} 
      images={project.processGallery || project.gallery?.filter(img => 
        img.category?.toLowerCase().includes('solution') || 
        img.category?.toLowerCase() === 'solución' ||
        img.category?.toLowerCase() === 'after' ||
        img.category?.toLowerCase() === 'ui'
      ).map(img => ({ image: img.image, caption: img.caption, category: img.category }))}
    />
  )}

  {project.aiIntegration && project.aiIntegration.length > 0 && (
    <AIIntegrationSection 
      aiIntegration={project.aiIntegration} 
      images={project.impactGallery || project.gallery?.filter(img => 
        img.category?.toLowerCase().includes('ai') || 
        img.category?.toLowerCase().includes('tool')
      ).map(img => ({ image: img.image, caption: img.caption, category: img.category }))}
    />
  )}

  {project.metrics && project.metrics.length > 0 && (
    <ImpactSection 
      impact={project.metrics.map(m => ({ metric: m.label, value: m.value, description: "" }))} 
      images={project.impactGallery}
    />
  )}

  {project.gallery && project.gallery.length > 0 && (
    <GallerySection images={project.gallery.map(g => ({ image: g.image, caption: g.caption, category: g.category || "Media" }))} />
  )}
</div>

<style is:global>
  .project-case-study {
    width: 100%;
  }

  /* Smooth scrolling */
  html {
    scroll-behavior: smooth;
  }

  /* Animation utilities */
  [data-aos] {
    opacity: 0;
    transition: opacity 0.3s ease-out;
  }

  [data-aos].aos-animate {
    opacity: 1;
  }
</style>
