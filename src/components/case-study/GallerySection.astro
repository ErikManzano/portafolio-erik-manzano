---
interface Props {
  images: Array<{
    image: string;
    caption: string;
    category: string;
  }>;
}

const { images = [] } = Astro.props;

if (!images || images.length === 0) {
  return null;
}

const grouped = images.reduce(
  (acc, img) => {
    const cat = img.category || "general";
    if (!acc[cat]) acc[cat] = [];
    acc[cat].push(img);
    return acc;
  },
  {} as Record<string, any[]>,
);

const categoryLabels = {
  before: "Antes",
  after: "Después",
  ui: "UI/Interfaz",
  flow: "Flujo de Usuario",
  interaction: "Interacciones",
  general: "Galería",
};
---

<section class="case-study-section py-5">
  <div class="container">
    <div class="row">
      <div class="col-lg-10">
        <div class="section-header" data-aos="fade-up">
          <span class="section-number">05</span>
          <h2 class="section-title">Galería de Trabajo</h2>
        </div>
      </div>
    </div>

    {
      Object.entries(grouped).map(([category, imgs]: any, categoryIdx) => (
        <div
          class="gallery-section mt-5"
          data-aos="fade-up"
          data-aos-delay={100 + categoryIdx * 100}
        >
          <div class="row">
            <div class="col-lg-10">
              <h3 class="category-title">
                {categoryLabels[category as keyof typeof categoryLabels] ||
                  category}
              </h3>
            </div>
          </div>

          <div class="row mt-3">
            <div class="col-12 col-lg-6 col-md-12">
              <div class="gallery-grid">
                {imgs.map((img: any, imgIdx: number) => (
                  <div
                    class="gallery-item"
                    data-aos="zoom-in"
                    data-aos-delay={150 + imgIdx * 50}
                  >
                    <div class="gallery-image-wrapper">
                      <a
                        href={img.image}
                        class="glightbox"
                        data-gallery={`gallery-${category}`}
                        data-glightbox={`title: ${img.caption}`}
                      >
                        <img src={img.image} alt={img.caption} loading="lazy" />
                      </a>
                    </div>
                    <p class="gallery-caption">{img.caption}</p>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
      ))
    }
  </div>
</section>

<style>
  .section-header {
    position: relative;
    margin-bottom: 3rem;
  }

  .section-number {
    display: block;
    font-size: 4rem;
    font-weight: 700;
    color: rgba(164, 128, 247, 0.15);
    line-height: 1;
    margin-bottom: -0.5rem;
  }

  .section-title {
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--color-heading);
  }

  .category-title {
    color: var(--color-brand);
    font-size: 1.1rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    font-weight: 700;
    margin-bottom: 1.5rem;
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1.5rem;
    max-width: 100%;
  }

  @media (min-width: 1200px) {
    .gallery-grid {
      grid-template-columns: repeat(2, 1fr);
      max-width: 900px;
    }
  }

  .gallery-item {
    border-radius: 0.75rem;
    overflow: hidden;
    background-color: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.1);
    transition: all 0.3s ease;
  }

  .gallery-item:hover {
    transform: translateY(-8px);
    background-color: rgba(255, 255, 255, 0.04);
    border-color: rgba(164, 128, 247, 0.3);
    box-shadow: 0 12px 32px rgba(164, 128, 247, 0.15);
  }

  .gallery-image-wrapper {
    width: 100%;
    height: auto;
    background-color: transparent;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 0.75rem;
  }

  .gallery-image-wrapper img {
    width: 100%;
    height: auto;
    max-height: 450px;
    display: block;
    transition: transform 0.3s ease;
    cursor: zoom-in;
    object-fit: contain;
  }

  .gallery-item:hover .gallery-image-wrapper img {
    transform: scale(1.05);
  }

  .gallery-caption {
    padding: 1.5rem;
    color: var(--color-body);
    font-size: 0.9rem;
    line-height: 1.5;
    margin: 0;
  }

  .case-study-section {
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  @media (max-width: 768px) {
    .section-number {
      font-size: 2.5rem;
    }

    .section-title {
      font-size: 1.8rem;
    }

    .gallery-grid {
      grid-template-columns: 1fr;
    }

    .gallery-image-wrapper {
      height: auto;
    }
  }

  /* CUSTOM LIGHTBOX STYLES */
  :root {
    --glightbox-btn-color: var(--color-brand);
    --glightbox-ctrl-bg: rgba(18, 18, 18, 0.5);
  }

  .glightbox-container .gcontainer {
    background: rgba(12, 12, 12, 0.95) !important;
    backdrop-filter: blur(15px);
  }

  /* Make images take more space */
  .gslide-image {
    max-width: 95vw !important;
    max-height: 90vh !important;
  }

  .gslide-image img {
    border-radius: 4px;
    box-shadow: 0 30px 60px rgba(0, 0, 0, 0.8);
    object-fit: contain;
  }

  .glightbox-clean .gslide-description {
    background: rgba(18, 18, 18, 0.9) !important;
    backdrop-filter: blur(5px);
    border-top: none;
    border-left: 4px solid var(--color-brand);
    color: var(--color-heading) !important;
    max-width: 800px !important;
    margin: 0 auto;
    border-bottom-left-radius: 8px;
    border-bottom-right-radius: 8px;
  }

  .glightbox-clean .gslide-title {
    color: var(--color-brand) !important;
    font-weight: 700 !important;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .glightbox-clean .gnext,
  .glightbox-clean .gprev,
  .glightbox-clean .gclose {
    background: var(--color-base) !important;
    border-radius: 50%;
    width: 50px;
    height: 50px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
  }

  .glightbox-clean .gnext:hover,
  .glightbox-clean .gprev:hover,
  .glightbox-clean .gclose:hover {
    background: var(--color-brand) !important;
  }

  .glightbox-clean .gnext svg,
  .glightbox-clean .gprev svg,
  .glightbox-clean .gclose svg {
    width: 20px;
    height: 20px;
  }

  .glightbox-clean .gnext svg path,
  .glightbox-clean .gprev svg path,
  .glightbox-clean .gclose svg path {
    fill: var(--color-brand);
  }

  .glightbox-clean .gnext:hover svg path,
  .glightbox-clean .gprev:hover svg path,
  .glightbox-clean .gclose:hover svg path {
    fill: var(--color-base);
  }

  .gslide-image img {
    border-radius: 8px;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.5);
  }

  @media (max-width: 768px) {
    .glightbox-clean .gslide-description {
      padding: 1.5rem !important;
    }
    .glightbox-clean .gnext,
    .glightbox-clean .gprev {
      display: none !important; /* On mobile touch is enough */
    }
  }
</style>

<link
  rel="stylesheet"
  href="https://cdn.jsdelivr.net/npm/glightbox/dist/css/glightbox.min.css"
/>
<script
  is:inline
  src="https://cdn.jsdelivr.net/gh/mcstudios/glightbox/dist/js/glightbox.min.js"
></script>

<script is:inline>
  document.addEventListener("astro:page-load", () => {
    const lightbox = GLightbox({
      touchNavigation: true,
      loop: true,
      autoplayVideos: true,
      zoomable: true,
      draggable: true,
    });
  });

  // Fallback for non-view-transitions
  const lightbox = GLightbox({
    touchNavigation: true,
    loop: true,
    autoplayVideos: true,
    zoomable: true,
    draggable: true,
  });
</script>
